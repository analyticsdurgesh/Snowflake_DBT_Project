airbnb_snowflake:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "your_snowflake_account"
      user: "your_snowflake_username"
      password: "your_snowflake_password"
      role: "ACCOUNTADMIN"
      database: "AIRBNB_ANALYTICS"
      warehouse: "COMPUTE_WH"
      schema: "ANALYTICS"
      threads: 4
      client_session_keep_alive: false
